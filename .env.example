# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, NEVER expose to the browser.
# Used to create client/admin login accounts (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string (Project Settings > Database > Connection string > URI).
# Use the "Transaction pooler" (port 6543) connection string for serverless hosting like Vercel.
DATABASE_URL=
